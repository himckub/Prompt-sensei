{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.codex/skills/prompt-sensei/dist/scripts/session-start.js",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.codex/skills/prompt-sensei/dist/scripts/observe.js --hash-only",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.codex/skills/prompt-sensei/dist/scripts/stop.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
